{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaos.dev/schemas/m15-cross-control-regression.schema.json",
  "title": "AAOS M15 Track D cross-control matrix and synthetic scenario",
  "oneOf": [
    {"$ref": "#/$defs/matrix"},
    {"$ref": "#/$defs/scenario"}
  ],
  "$defs": {
    "token": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,95}$"},
    "reference": {"type": "string", "minLength": 2, "maxLength": 512},
    "matrixEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control_id", "control_domain", "source_track", "source_artifact_type", "protected_boundary", "attempted_bypass", "required_external_control", "expected_outcome", "evidence_reference", "test_reference", "authority_boundary", "notes"],
      "properties": {
        "control_id": {"$ref": "#/$defs/token"},
        "control_domain": {"enum": ["public-output-safety", "provenance-human-review", "capability-admission", "evidence-admission", "authority-boundary", "decision-proof-ownership", "release-m15-status"]},
        "source_track": {"enum": ["track-a", "track-b", "track-c", "cross-track"]},
        "source_artifact_type": {"$ref": "#/$defs/token"},
        "protected_boundary": {"type": "string", "minLength": 8},
        "attempted_bypass": {"type": "string", "minLength": 8},
        "required_external_control": {"type": "string", "minLength": 3},
        "expected_outcome": {"enum": ["pass", "reject", "quarantine"]},
        "evidence_reference": {"$ref": "#/$defs/reference"},
        "test_reference": {"$ref": "#/$defs/reference"},
        "authority_boundary": {"type": "string", "minLength": 8},
        "notes": {"type": "string", "minLength": 3}
      }
    },
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "matrix_id", "tracker", "m15_status", "release_status", "controls", "non_authoritative_boundary_statement"],
      "properties": {
        "schema_version": {"const": "m15-cross-control-regression/v1"},
        "matrix_id": {"const": "m15-track-d-cross-control-matrix"},
        "tracker": {"const": "#231-open"},
        "m15_status": {"const": "active-incomplete"},
        "release_status": {"const": "v0.14.0-unpublished"},
        "controls": {"type": "array", "minItems": 15, "items": {"$ref": "#/$defs/matrixEntry"}},
        "non_authoritative_boundary_statement": {"const": "Track D evidence grants no authority; Learning Proof and Decision Proof sealing remain AAOS-owned; AAOS remains the decision sovereignty layer."}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "scenario_id", "title", "source_track", "synthetic", "expected_outcome", "record", "notes"],
      "properties": {
        "schema_version": {"const": "m15-cross-control-regression/v1"},
        "scenario_id": {"type": "string", "pattern": "^m15-track-d-[0-9]{2}$"},
        "title": {"type": "string", "minLength": 8},
        "source_track": {"enum": ["track-a", "track-b", "track-c", "cross-track", "provenance"]},
        "synthetic": {"const": true},
        "expected_outcome": {"enum": ["pass", "reject", "quarantine"]},
        "record": {"type": "object"},
        "notes": {"type": "string", "minLength": 3}
      }
    }
  }
}
