    "declaredVerificationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "argv",
        "test_scope",
        "execution_scope",
        "minimum_tests_observed",
        "required",
        "expected_exit_code",
        "executed_by_evaluator"
