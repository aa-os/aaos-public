        "e1_pull_request_number": {"const": 243},
        "e1_receipt_comment_id": {"const": 5015070053},
        "e1_receipt_canonical_sha256": {"const": "86e33a67a532b11502b376f196a755b62a72a487e5f754cc2ac3752082acbb5b"}
      }
