        "artifact_role": {
          "enum": [
            "governance-contract",
            "standalone-synthetic-fixture",
            "operational-readiness-manifest",
            "offline-evaluator",
            "strict-schema",
            "focused-tests"
          ]
        },
        "required_status": {"const": "required"},
        "evidence_reference": {"$ref": "#/$defs/reference"}
