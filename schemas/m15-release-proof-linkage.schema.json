      "properties": {
        "path_id": {"type": "string", "pattern": "^m15-e2-e1-path-[0-9]{2}$"},
        "path": {"type": "string", "pattern": "^[^\\\\:]+(?:/[^/\\\\:]+)*$"},
        "previous_path": {
