{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaos.dev/schemas/m15-operational-readiness.schema.json",
  "title": "AAOS M15 Track E1 Operational Readiness Package",
  "oneOf": [
    {"$ref": "#/$defs/maintainedManifest"},
    {"$ref": "#/$defs/syntheticScenario"}
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "gitCommitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "trackBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "source_issue",
        "implementation_pr",
        "head_sha",
        "merge_sha",
        "schema_version",
        "artifact_count",
        "implementation_state"
      ],
      "properties": {
        "track_id": {"enum": ["track-a", "track-b", "track-c", "track-d"]},
        "source_issue": {"enum": ["#232", "#234", "#238", "#240"]},
        "implementation_pr": {"enum": ["#233", "#237", "#239", "#241"]},
        "head_sha": {"$ref": "#/$defs/gitCommitSha"},
        "merge_sha": {"$ref": "#/$defs/gitCommitSha"},
        "schema_version": {
          "enum": [
            "m15-learning-proof/v1",
            "m15-capability-memory-pack/v1",
            "m15-lineage-rollback-portability/v1",
            "m15-cross-control-regression/v1"
          ]
        },
        "artifact_count": {"type": "integer", "minimum": 1},
        "implementation_state": {"const": "merged-into-maintained-main"}
      }
    },
    "artifactEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "source_issue",
        "implementation_pr",
        "relative_path",
        "artifact_type",
        "required",
        "digest_algorithm",
        "digest_mode",
        "maintained_canonical_sha256",
        "test_module",
        "executable_by_evaluator"
      ],
      "properties": {
        "track_id": {"enum": ["track-a", "track-b", "track-c", "track-d"]},
        "source_issue": {"enum": ["#232", "#234", "#238", "#240"]},
        "implementation_pr": {"enum": ["#233", "#237", "#239", "#241"]},
        "relative_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\\\:]+(?:/[^/\\\\:]+)*$"
        },
        "artifact_type": {
          "enum": [
            "contract",
            "schema",
            "fixture",
            "cross-control-matrix",
            "evaluator",
            "test"
          ]
        },
        "required": {"const": true},
        "digest_algorithm": {"const": "sha256"},
        "digest_mode": {"const": "canonical-text"},
        "maintained_canonical_sha256": {"$ref": "#/$defs/sha256"},
        "test_module": {
          "enum": [
            "tests.test_m15_learning_proof_evaluator",
            "tests.test_m15_capability_memory_pack_evaluator",
            "tests.test_m15_lineage_rollback_portability_evaluator",
            "tests.test_m15_cross_control_regression_evaluator"
          ]
        },
        "executable_by_evaluator": {"const": false}
      }
    },
    "artifactInventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest_algorithm",
        "digest_mode",
        "canonicalization",
        "historical_digest_evidence_policy",
        "artifact_count",
        "track_artifact_counts",
        "artifact_type_counts",
        "artifacts"
      ],
      "properties": {
        "digest_algorithm": {"const": "sha256"},
        "digest_mode": {"const": "canonical-text"},
        "canonicalization": {"const": "strict-utf8-crlf-to-lf-only"},
        "historical_digest_evidence_policy": {"const": "preserved-separate-and-unmodified"},
        "artifact_count": {"const": 67},
        "track_artifact_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["track-a", "track-b", "track-c", "track-d"],
          "properties": {
            "track-a": {"const": 7},
            "track-b": {"const": 13},
            "track-c": {"const": 18},
            "track-d": {"const": 29}
          }
        },
        "artifact_type_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contract", "schema", "fixture", "cross-control-matrix", "evaluator", "test"],
          "properties": {
            "contract": {"const": 4},
            "schema": {"const": 4},
            "fixture": {"const": 50},
            "cross-control-matrix": {"const": 1},
            "evaluator": {"const": 4},
            "test": {"const": 4}
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 67,
          "maxItems": 67,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/artifactEntry"}
        }
      }
    },
    "verificationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "argv",
        "test_scope",
        "required",
        "expected_exit_code",
        "executed_by_evaluator"
      ],
      "properties": {
        "command_id": {
          "type": "string",
          "pattern": "^run_[a-z0-9_]+$"
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "test_scope": {"type": "string", "minLength": 1},
        "required": {"const": true},
        "expected_exit_code": {"const": 0},
        "executed_by_evaluator": {"const": false}
      }
    },
    "verificationCommandManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_count",
        "environment",
        "execution_policy",
        "executed_by_evaluator",
        "execution_results_recorded",
        "verification_results_are_completion_approval",
        "commands"
      ],
      "properties": {
        "command_count": {"const": 13},
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["PYTHONDONTWRITEBYTECODE"],
          "properties": {
            "PYTHONDONTWRITEBYTECODE": {"const": "1"}
          }
        },
        "execution_policy": {"const": "declarative-only-not-executed-by-evaluator"},
        "executed_by_evaluator": {"const": false},
        "execution_results_recorded": {"const": false},
        "verification_results_are_completion_approval": {"const": false},
        "commands": {
          "type": "array",
          "minItems": 13,
          "maxItems": 13,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/verificationCommand"}
        }
      }
    },
    "governanceBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tracker_231_state",
        "m15_state",
        "v0_14_0_state",
        "completion_approved",
        "tracker_closure_authorized",
        "readme_completion_authorized",
        "readme_release_authorized",
        "tag_created",
        "tag_creation_authorized",
        "release_authorized",
        "github_release_created",
        "github_release_publication_authorized",
        "authority_transferred"
      ],
      "properties": {
        "tracker_231_state": {"const": "open"},
        "m15_state": {"const": "active-and-incomplete"},
        "v0_14_0_state": {"const": "unpublished"},
        "completion_approved": {"const": false},
        "tracker_closure_authorized": {"const": false},
        "readme_completion_authorized": {"const": false},
        "readme_release_authorized": {"const": false},
        "tag_created": {"const": false},
        "tag_creation_authorized": {"const": false},
        "release_authorized": {"const": false},
        "github_release_created": {"const": false},
        "github_release_publication_authorized": {"const": false},
        "authority_transferred": {"const": false}
      }
    },
    "maintainedManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "document_type",
        "record_id",
        "issue",
        "track",
        "maintained_repository",
        "maintained_branch",
        "maintained_main_commit_sha",
        "parent_tracker",
        "source_track_bindings",
        "artifact_integrity_inventory",
        "verification_command_manifest",
        "known_repository_local_completion_blockers",
        "governance_boundary",
        "allowed_outcomes",
        "declared_outcome",
        "non_authoritative_boundary_statement"
      ],
      "properties": {
        "schema_version": {"const": "m15-operational-readiness/v1"},
        "document_type": {"const": "maintained-operational-readiness-manifest"},
        "record_id": {"const": "urn:aaos:m15:operational-readiness:e1:maintained-main"},
        "issue": {"const": "#242"},
        "track": {"const": "E1"},
        "maintained_repository": {"const": "aa-os/aaos-public"},
        "maintained_branch": {"const": "main"},
        "maintained_main_commit_sha": {"const": "e4681dfbc9c7cc69372b0e44bc6d2f2da034d88f"},
        "parent_tracker": {"const": "#231"},
        "source_track_bindings": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/trackBinding"}
        },
        "artifact_integrity_inventory": {"$ref": "#/$defs/artifactInventory"},
        "verification_command_manifest": {"$ref": "#/$defs/verificationCommandManifest"},
        "known_repository_local_completion_blockers": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "governance_boundary": {"$ref": "#/$defs/governanceBoundary"},
        "allowed_outcomes": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {"const": "ready_for_completion_review"},
            {"const": "not_ready"},
            {"const": "blocked"}
          ],
          "items": false
        },
        "declared_outcome": {
          "enum": ["ready_for_completion_review", "not_ready", "blocked"]
        },
        "non_authoritative_boundary_statement": {
          "const": "ready_for_completion_review is evidence for a later human completion review only; it is not M15 completion approval, tracker #231 closure, README completion or release authorization, tag authorization, release authorization, or GitHub Release publication authorization."
        }
      }
    },
    "scenarioEvidenceState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_shape_valid",
        "maintained_main_binding_valid",
        "source_track_bindings_valid",
        "artifact_inventory_complete",
        "artifact_integrity_valid",
        "internal_consistency_valid",
        "cross_control_matrix_bound",
        "test_coverage_complete",
        "verification_command_manifest_complete",
        "verification_execution_claimed",
        "authority_boundary_valid",
        "completion_approval_claimed",
        "tracker_closure_claimed",
        "m15_completion_claimed",
        "readme_authorization_claimed",
        "tag_authorization_or_creation_claimed",
        "release_authorization_or_publication_claimed",
        "known_repository_local_completion_blockers"
      ],
      "properties": {
        "manifest_shape_valid": {"type": "boolean"},
        "maintained_main_binding_valid": {"type": "boolean"},
        "source_track_bindings_valid": {"type": "boolean"},
        "artifact_inventory_complete": {"type": "boolean"},
        "artifact_integrity_valid": {"type": "boolean"},
        "internal_consistency_valid": {"type": "boolean"},
        "cross_control_matrix_bound": {"type": "boolean"},
        "test_coverage_complete": {"type": "boolean"},
        "verification_command_manifest_complete": {"type": "boolean"},
        "verification_execution_claimed": {"type": "boolean"},
        "authority_boundary_valid": {"type": "boolean"},
        "completion_approval_claimed": {"type": "boolean"},
        "tracker_closure_claimed": {"type": "boolean"},
        "m15_completion_claimed": {"type": "boolean"},
        "readme_authorization_claimed": {"type": "boolean"},
        "tag_authorization_or_creation_claimed": {"type": "boolean"},
        "release_authorization_or_publication_claimed": {"type": "boolean"},
        "known_repository_local_completion_blockers": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "syntheticScenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "document_type",
        "scenario_id",
        "title",
        "synthetic",
        "expected_outcome",
        "evidence_state",
        "notes"
      ],
      "properties": {
        "schema_version": {"const": "m15-operational-readiness-scenario/v1"},
        "document_type": {"const": "synthetic-scenario"},
        "scenario_id": {
          "enum": [
            "m15-e1-01",
            "m15-e1-02",
            "m15-e1-03",
            "m15-e1-04",
            "m15-e1-05",
            "m15-e1-06",
            "m15-e1-07",
            "m15-e1-08",
            "m15-e1-09",
            "m15-e1-10",
            "m15-e1-11",
            "m15-e1-12",
            "m15-e1-13",
            "m15-e1-14",
            "m15-e1-15",
            "m15-e1-16",
            "m15-e1-17",
            "m15-e1-18"
          ]
        },
        "title": {
          "enum": [
            "Valid maintained-main operational-readiness evidence",
            "Maintained-main commit binding mismatch",
            "Merged source-track binding mismatch",
            "Incomplete Track A-D artifact inventory",
            "Maintained artifact integrity failure",
            "Operational-readiness internal consistency failure",
            "Track D cross-control matrix is not bound",
            "Deterministic test coverage is incomplete",
            "Verification-command manifest is incomplete",
            "Verification manifest claims command execution",
            "Operational readiness claims completion approval",
            "Operational readiness claims tracker closure",
            "Operational readiness claims M15 completion",
            "Operational readiness claims README authorization",
            "Operational readiness claims tag authority or creation",
            "Operational readiness claims release authority or publication",
            "Known repository-local completion blocker remains unresolved",
            "Unsupported operational-readiness scenario schema version"
          ]
        },
        "synthetic": {"const": true},
        "expected_outcome": {
          "enum": ["ready_for_completion_review", "not_ready", "blocked"]
        },
        "evidence_state": {"$ref": "#/$defs/scenarioEvidenceState"},
        "notes": {
          "const": "This standalone scenario is synthetic, inert, offline, and non-authoritative. ready_for_completion_review is evidence for a later human completion review only; it is not M15 completion approval, tracker #231 closure, README completion or release authorization, tag authorization, release authorization, or GitHub Release publication authorization."
        }
      }
    }
  }
}
