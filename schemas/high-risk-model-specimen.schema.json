{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaos.dev/schemas/high-risk-model-specimen.schema.json",
  "title": "AAOS High-Risk Model Specimen Registry Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specimen_id",
    "specimen_type",
    "source_model_ref",
    "modification_class",
    "risk_tags",
    "allowed_environment",
    "blocked_capabilities",
    "containment_controls",
    "provenance_status",
    "trace_logging_required",
    "replay_required",
    "fail_closed_required",
    "advisor_invocation",
    "test_scenarios",
    "observed_behavior",
    "comparison_baseline",
    "rollback_rule",
    "not_authority_statement",
    "sovereignty_statement"
  ],
  "properties": {
    "specimen_id": {
      "type": "string"
    },
    "specimen_type": {
      "type": "string",
      "const": "high_risk_adversarial_model_modification"
    },
    "source_model_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_name",
        "model_family",
        "model_version",
        "source_uri",
        "source_hash"
      ],
      "properties": {
        "model_name": {
          "type": "string"
        },
        "model_family": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "source_uri": {
          "type": "string"
        },
        "source_hash": {
          "type": "string"
        }
      }
    },
    "modification_class": {
      "type": "string",
      "enum": [
        "decensored",
        "alignment_removed",
        "safety_alignment_degraded",
        "unknown_modification"
      ]
    },
    "risk_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "high_risk",
          "decensored",
          "alignment_removed",
          "safety_degraded",
          "adversarial_specimen",
          "no_production_tools"
        ]
      }
    },
    "allowed_environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_type",
        "network_access",
        "write_access",
        "credential_access",
        "production_tool_access"
      ],
      "properties": {
        "environment_type": {
          "type": "string",
          "enum": [
            "isolated_local_sandbox"
          ]
        },
        "network_access": {
          "type": "boolean"
        },
        "write_access": {
          "type": "boolean"
        },
        "credential_access": {
          "type": "boolean"
        },
        "production_tool_access": {
          "type": "boolean"
        }
      }
    },
    "blocked_capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "network_access",
          "write_access",
          "credential_access",
          "production_tool_access",
          "autonomous_action_execution",
          "scheduler_control",
          "workflow_routing",
          "decision_router_authority",
          "approval_chain_bypass",
          "policy_layer_modification"
        ]
      }
    },
    "containment_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isolated_local_sandbox",
        "no_network_access",
        "no_write_access",
        "no_credential_access",
        "no_production_tools",
        "full_trace_logging",
        "read_only_fixtures",
        "no_autonomous_execution",
        "no_scheduler_control",
        "replay_ready_evidence",
        "fail_closed_enforced"
      ],
      "properties": {
        "isolated_local_sandbox": {
          "type": "boolean"
        },
        "no_network_access": {
          "type": "boolean"
        },
        "no_write_access": {
          "type": "boolean"
        },
        "no_credential_access": {
          "type": "boolean"
        },
        "no_production_tools": {
          "type": "boolean"
        },
        "full_trace_logging": {
          "type": "boolean"
        },
        "read_only_fixtures": {
          "type": "boolean"
        },
        "no_autonomous_execution": {
          "type": "boolean"
        },
        "no_scheduler_control": {
          "type": "boolean"
        },
        "replay_ready_evidence": {
          "type": "boolean"
        },
        "fail_closed_enforced": {
          "type": "boolean"
        }
      }
    },
    "provenance_status": {
      "type": "string",
      "enum": [
        "verified_untrusted",
        "unknown",
        "unsafe",
        "unverified"
      ]
    },
    "trace_logging_required": {
      "type": "boolean"
    },
    "replay_required": {
      "type": "boolean"
    },
    "fail_closed_required": {
      "type": "boolean"
    },
    "advisor_invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "contract_ref",
        "trigger_types",
        "review_reason",
        "status",
        "decision_owner"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "contract_ref": {
          "type": "string",
          "const": "advisor_invocation_boundary"
        },
        "trigger_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "high_risk_adversarial_specimen",
              "adapter_authority_boundary_uncertainty",
              "high_or_critical_risk_signal",
              "human_review_required_but_missing",
              "fail_closed_override_request"
            ]
          }
        },
        "review_reason": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "completed",
            "not_required"
          ]
        },
        "decision_owner": {
          "type": "string"
        }
      }
    },
    "test_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scenario_id",
          "category",
          "purpose",
          "replay_ready",
          "production_tools_blocked"
        ],
        "properties": {
          "scenario_id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "alignment_drift_detection",
              "refusal_degradation_detection",
              "unsafe_model_provenance_detection",
              "tool_misuse_precheck",
              "fail_closed_simulation",
              "red_team_scenario_execution",
              "decision_replay_under_compromised_model_behavior"
            ]
          },
          "purpose": {
            "type": "string"
          },
          "replay_ready": {
            "type": "boolean"
          },
          "production_tools_blocked": {
            "type": "boolean"
          }
        }
      }
    },
    "observed_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alignment_drift_observed",
        "refusal_degradation_observed",
        "unsafe_behavior_observed",
        "notes"
      ],
      "properties": {
        "alignment_drift_observed": {
          "type": "boolean"
        },
        "refusal_degradation_observed": {
          "type": "boolean"
        },
        "unsafe_behavior_observed": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "comparison_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_model_ref",
        "baseline_behavior_summary",
        "drift_signal"
      ],
      "properties": {
        "baseline_model_ref": {
          "type": "string"
        },
        "baseline_behavior_summary": {
          "type": "string"
        },
        "drift_signal": {
          "type": "string"
        }
      }
    },
    "rollback_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "rule_ref",
        "trigger",
        "decision_owner"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "rule_ref": {
          "type": "string"
        },
        "trigger": {
          "type": "string"
        },
        "decision_owner": {
          "type": "string"
        }
      }
    },
    "not_authority_statement": {
      "type": "string"
    },
    "sovereignty_statement": {
      "type": "string"
    }
  }
}
