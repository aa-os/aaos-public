{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaos.dev/schemas/skill-change-audit.schema.json",
  "title": "AAOS Skill Change Audit Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_id",
    "skill_id",
    "skill_version",
    "change_set_id",
    "optimizer_ref",
    "accepted_edits",
    "rejected_edits",
    "validation_evidence",
    "regression_results",
    "rollout_trace",
    "history_log",
    "replay_dataset",
    "policy_precheck_result",
    "deployment_gate_status",
    "rollback_readiness",
    "advisor_invocation",
    "aaos_decision_state",
    "evidence_hashes",
    "not_authority_statement",
    "sovereignty_statement"
  ],
  "properties": {
    "audit_id": {
      "type": "string"
    },
    "skill_id": {
      "type": "string"
    },
    "skill_version": {
      "type": "string"
    },
    "change_set_id": {
      "type": "string"
    },
    "optimizer_ref": {
      "type": "string"
    },
    "accepted_edits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected_edits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "regression_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rollout_trace": {
      "type": "string"
    },
    "history_log": {
      "type": "string"
    },
    "replay_dataset": {
      "type": "string"
    },
    "policy_precheck_result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "incomplete"
      ]
    },
    "deployment_gate_status": {
      "type": "string",
      "enum": [
        "ready_for_aaos_review",
        "pending_aaos_approval",
        "pass",
        "fail",
        "incomplete"
      ]
    },
    "rollback_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ready",
        "plan_ref",
        "owner"
      ],
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "plan_ref": {
          "type": "string"
        },
        "owner": {
          "type": "string",
          "const": "AAOS"
        }
      }
    },
    "advisor_invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "contract_ref",
        "trigger_types",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "contract_ref": {
          "type": "string",
          "const": "advisor_invocation_boundary"
        },
        "trigger_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "completed",
            "not_required"
          ]
        }
      }
    },
    "aaos_decision_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_owner",
        "deployment_decision",
        "audit_judgment_state"
      ],
      "properties": {
        "decision_owner": {
          "type": "string",
          "const": "AAOS"
        },
        "deployment_decision": {
          "type": "string"
        },
        "audit_judgment_state": {
          "type": "string"
        }
      }
    },
    "evidence_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "not_authority_statement": {
      "type": "string"
    },
    "sovereignty_statement": {
      "type": "string"
    }
  }
}
