        "generated_source_archives_excluded",
        "inventory_result"
      ],
      "properties": {
        "uploaded_asset_count": {
          "type": "integer",
          "minimum": 0
        },
        "uploaded_assets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "asset_id",
              "name",
              "size_bytes",
              "content_type",
              "download_url",
              "sha256"
            ],
