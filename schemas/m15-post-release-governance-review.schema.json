              "asset_id": {
                "type": "integer",
                "minimum": 1
              },
              "name": {
                "$ref": "#/$defs/reference"
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "content_type": {
                "$ref": "#/$defs/reference"
              },
              "download_url": {
                "$ref": "#/$defs/reference"
              },
