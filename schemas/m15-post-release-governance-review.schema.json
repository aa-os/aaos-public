            "claims_decision_proof_sealing": {
              "const": false
            },
            "claims_learning_proof_sealing": {
              "const": false
            },
            "claims_release_as_governance_approval": {
              "const": false
            },
            "claims_risk_acceptance": {
              "const": false
            },
            "claims_runtime_authority": {
              "const": false
            }
          }
