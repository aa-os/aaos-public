            "commit_sha": {
              "$ref": "#/$defs/gitSha"
            },
            "tree_sha": {
              "$ref": "#/$defs/gitSha"
            }
          }
        },
        "maintained_main": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidence_role",
            "ref",
            "commit_sha",
            "observed_at"
          ],
          "properties": {
            "evidence_role": {
              "const": "mutable-maintained-repository-observation"
            },
            "ref": {
              "const": "refs/heads/main"
            },
            "commit_sha": {
              "$ref": "#/$defs/gitSha"
            },
            "observed_at": {
              "$ref": "#/$defs/rfc3339Utc"
            }
          }
        },
        "live_github": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidence_role",
            "release_id",
            "observed_at",
            "external_state_mutable"
          ],
          "properties": {
            "evidence_role": {
              "const": "mutable-live-github-observation"
            },
            "release_id": {
              "const": 356696715
            },
            "observed_at": {
              "$ref": "#/$defs/rfc3339Utc"
            },
            "external_state_mutable": {
              "const": true
            }
          }
        },
        "clean_clone": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidence_role",
            "clone_url",
            "resolved_commit_sha",
            "working_tree_clean"
          ],
          "properties": {
            "evidence_role": {
              "const": "independent-reproducibility-observation"
            },
            "clone_url": {
              "const": "https://github.com/aa-os/aaos-public.git"
            },
            "resolved_commit_sha": {
              "$ref": "#/$defs/gitSha"
            },
            "working_tree_clean": {
              "const": true
            }
          }
        }
      }
    },
    "tagReleaseBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tag_name",
        "tag_ref",
        "tag_object_type",
        "annotated_tag_object_sha",
        "tag_ref_target_sha",
        "peeled_commit_sha",
        "target_tree_sha",
        "expected_merge_commit_sha",
        "completion_pr_head_sha",
        "target_equals_expected_merge_commit",
        "target_equals_completion_pr_head",
        "release_tag_name",
        "release_target_commitish",
        "release_resolved_commit_sha",
        "tag_and_release_binding_match",
        "point_in_time_observation_only",
        "historical_non_movement_proven"
      ],
      "properties": {
        "tag_name": {
          "const": "v0.14.0"
        },
        "tag_ref": {
          "const": "refs/tags/v0.14.0"
        },
        "tag_object_type": {
          "const": "commit"
        },
        "annotated_tag_object_sha": {
