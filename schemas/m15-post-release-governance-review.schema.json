        "target_equals_completion_pr_head": {
          "const": false
        },
        "release_tag_name": {
          "const": "v0.14.0"
        },
        "release_target_commitish": {
          "const": "main"
        },
        "release_resolved_commit_sha": {
          "$ref": "#/$defs/gitSha"
        },
        "tag_and_release_binding_match": {
          "const": true
        },
        "point_in_time_observation_only": {
          "const": true
        },
        "historical_non_movement_proven": {
          "const": false
        }
      }
