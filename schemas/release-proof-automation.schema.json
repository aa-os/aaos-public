{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaos.dev/schemas/release-proof-automation.schema.json",
  "title": "AAOS Release Proof Automation Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release_id",
    "release_title",
    "tracker_issue",
    "closing_prs",
    "release_tag",
    "readme_version_status",
    "release_title_consistency",
    "release_body_consistency",
    "next_phase_declaration",
    "decision_proof_replay_packet",
    "governance_boundary_preservation",
    "automation_checks",
    "evaluator_outputs",
    "not_authority_statement",
    "sovereignty_statement"
  ],
  "properties": {
    "release_id": {
      "type": "string"
    },
    "release_title": {
      "type": "string"
    },
    "tracker_issue": {
      "type": "string"
    },
    "closing_prs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pr",
          "title",
          "merged"
        ],
        "properties": {
          "pr": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "merged": {
            "type": "boolean"
          }
        }
      }
    },
    "release_tag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tag",
        "present"
      ],
      "properties": {
        "tag": {
          "type": "string"
        },
        "present": {
          "type": "boolean"
        }
      }
    },
    "readme_version_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "present",
        "status_text"
      ],
      "properties": {
        "version": {
          "type": "string"
        },
        "present": {
          "type": "boolean"
        },
        "status_text": {
          "type": "string"
        }
      }
    },
    "release_title_consistency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readme_title",
        "release_title",
        "matches"
      ],
      "properties": {
        "readme_title": {
          "type": "string"
        },
        "release_title": {
          "type": "string"
        },
        "matches": {
          "type": "boolean"
        }
      }
    },
    "release_body_consistency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governance_boundary_preserved",
        "body_summary"
      ],
      "properties": {
        "governance_boundary_preserved": {
          "type": "boolean"
        },
        "body_summary": {
          "type": "string"
        }
      }
    },
    "next_phase_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected",
        "actual",
        "matches_expected"
      ],
      "properties": {
        "expected": {
          "type": "string"
        },
        "actual": {
          "type": "string"
        },
        "matches_expected": {
          "type": "boolean"
        }
      }
    },
    "decision_proof_replay_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_ref",
        "present",
        "replay_ready"
      ],
      "properties": {
        "packet_ref": {
          "type": "string"
        },
        "present": {
          "type": "boolean"
        },
        "replay_ready": {
          "type": "boolean"
        }
      }
    },
    "governance_boundary_preservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserved",
        "aaos_retained_authority"
      ],
      "properties": {
        "preserved": {
          "type": "boolean"
        },
        "aaos_retained_authority": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "automation_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readme_version_status",
        "tracker_issue_closure",
        "pr_merge_status",
        "release_tag_presence",
        "release_title_consistency",
        "release_body_consistency",
        "next_phase_declaration",
        "decision_proof_replay_packet_presence",
        "governance_boundary_preservation"
      ],
      "properties": {
        "readme_version_status": {
          "type": "boolean"
        },
        "tracker_issue_closure": {
          "type": "boolean"
        },
        "pr_merge_status": {
          "type": "boolean"
        },
        "release_tag_presence": {
          "type": "boolean"
        },
        "release_title_consistency": {
          "type": "boolean"
        },
        "release_body_consistency": {
          "type": "boolean"
        },
        "next_phase_declaration": {
          "type": "boolean"
        },
        "decision_proof_replay_packet_presence": {
          "type": "boolean"
        },
        "governance_boundary_preservation": {
          "type": "boolean"
        }
      }
    },
    "evaluator_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "replay_packet_valid",
          "replay_packet_invalid",
          "replay_findings",
          "missing_evidence",
          "authority_boundary_violation",
          "release_proof_consistency_passed",
          "release_proof_consistency_failed",
          "review_required",
          "escalation_required",
          "fail_closed_recommended"
        ]
      }
    },
    "not_authority_statement": {
      "type": "string"
    },
    "sovereignty_statement": {
      "type": "string"
    }
  }
}
